#!/bin/sh
# omo-install — team-memory skills + Director agent をプロジェクトにコピー
# Usage: omo-install [--global]

set -eu

GLOBAL="${1:-}"
PKG="$(npm root -g)/opencode-team-memory"

if [ "$GLOBAL" = "--global" ]; then
  SKILL_DST="$HOME/.config/opencode/skills"
  AGENT_DST="$HOME/.config/opencode/agents"
else
  SKILL_DST="$(pwd)/.opencode/skills"
  AGENT_DST="$(pwd)/.opencode/agents"
fi

if [ ! -d "$PKG/.opencode/skills" ]; then
  echo "Error: package not found. Run: npm install -g opencode-team-memory" >&2
  exit 1
fi

copied=0

# ── Skills ──
mkdir -p "$SKILL_DST"
for skill_dir in "$PKG/.opencode/skills"/*; do
  [ -d "$skill_dir" ] || continue
  name=$(basename "$skill_dir")
  case "$name" in
    tm-engineer|tm-tester|tm-designer)
      cp -r "$skill_dir" "$SKILL_DST/"
      echo "  ✓ skill: $name"
      copied=$((copied + 1))
      ;;
  esac
done

# ── Director Agent ──
if [ -f "$PKG/.opencode/agents/director.md" ]; then
  mkdir -p "$AGENT_DST"
  cp "$PKG/.opencode/agents/director.md" "$AGENT_DST/"
  echo "  ✓ agent: director"
  copied=$((copied + 1))
fi

echo ""
echo "Installed $copied items to project"
echo "Restart opencode if already running."
