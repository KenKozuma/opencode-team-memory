#!/bin/sh
# omo-skill-generate — 閾値超過パターンを SKILL.md に変換
# Usage: omo-skill-generate --role=<engineer|tester|designer|director> [--pattern=<name>]

set -eu

MEMORY_DIR="${OPENCODE_TEAM_MEMORY_DIR:-$(pwd)/.omo/team-memory}"
SKILLS_DIR="$(pwd)/.opencode/skills"
ROLE=""
PATTERN=""

for arg in "$@"; do
  case "$arg" in
    --role=*) ROLE="${arg#--role=}" ;;
    --pattern=*) PATTERN="${arg#--pattern=}" ;;
    --help|-h) echo "Usage: omo-skill-generate --role=<role> [--pattern=<name>]" >&2; exit 0 ;;
    *) echo "Unknown: $arg" >&2; exit 1 ;;
  esac
done

if [ -z "$ROLE" ]; then
  echo "Error: --role is required" >&2; exit 1
fi

REFS_FILE="$MEMORY_DIR/$ROLE/references.json"
if [ ! -f "$REFS_FILE" ]; then
  echo "Error: No references found for role '$ROLE'" >&2; exit 1
fi

mkdir -p "$SKILLS_DIR"

generate_one() {
  _name="$1"
  _count="$2"
  _solution="$3"
  _role="$4"

  slug=$(echo "$_name" | tr 'A-Z ' 'a-z-' | sed 's/[^a-z0-9-]//g; s/--*/-/g; s/^-//; s/-$//')
  dir="$SKILLS_DIR/$slug"
  mkdir -p "$dir"
  generated_date=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

  cat > "$dir/SKILL.md" << EOF
---
name: $slug
description: Auto-generated skill (${_count} references). ${_name}
license: MIT
compatibility: opencode
metadata:
  source: opencode-team-memory
  role: ${_role}
  references: ${_count}
  generated: ${generated_date}
---

# ${_name}

Auto-generated from ${_count} successful pattern references by ${_role}.

## Solution

${_solution}

## When to Use

This pattern has been validated ${_count} times by ${_role}.
Apply when encountering this class of problem.

## Usage

Agent should load this skill via \`skill({ name: "${slug}" })\` when the problem matches.
EOF

  echo "  ✓ $slug ($_name : $_count refs)"
}

echo "" >&2
echo "Skill Generation: $ROLE" >&2
echo "========================================" >&2

export _GEN_REFS="$REFS_FILE"
tmpfile=$(mktemp /tmp/omo-patterns-XXXXXX.txt)
trap "rm -f $tmpfile" EXIT

python3 -c "
import json, os
refs = json.load(open(os.environ['_GEN_REFS']))
for name, entry in sorted(refs.items(), key=lambda x: -x[1]['count']):
    if entry['count'] >= 3:
        print(f'{name}\t{entry[\"count\"]}\t{entry[\"solution\"]}')
" 2>/dev/null > "$tmpfile"

generated=0
while IFS='	' read -r name count solution; do
  if [ -n "$PATTERN" ] && [ "$name" != "$PATTERN" ]; then
    continue
  fi
  generate_one "$name" "$count" "$solution" "$ROLE"
  generated=$((generated + 1))
done < "$tmpfile"

if [ "$generated" -eq 0 ]; then
  echo "  (no patterns reached threshold of 3)" >&2
fi

echo "========================================" >&2
echo "Skills directory: $SKILLS_DIR" >&2
echo "Restart opencode to load new skills." >&2
